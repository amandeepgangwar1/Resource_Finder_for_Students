# MongoDB Atlas or local MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/resource-finder

# Use a long random value in production
JWT_SECRET=replace_with_a_long_random_secret

# Optional: Hugging Face token for hosted AI inference features
HF_API_KEY=

# Backend server port
PORT=5000

# Runtime environment
NODE_ENV=development

# Optional backend CORS allowlist. Use your Vercel URL in production.
# Multiple origins can be comma-separated.
CORS_ORIGIN=

# Render-only: pin Node to an LTS version
NODE_VERSION=20

# Vercel-only: your Render backend origin, for example:
# FRONTEND_API_ORIGIN=https://student-resource-finder-api.onrender.com
FRONTEND_API_ORIGIN=
